#!/bin/bash

# gmode - GPU/CPU performance mode script
# Enhanced version with Profiles and Custom values

set -e

# Hardware Constraints (Auto-detected if possible, but these are safe defaults for this system)
CPU_MIN=800
CPU_MAX=3500
GPU_MIN=210
GPU_MAX=3105

# Profiles: "CPU_MHz GPU_MHz"
declare -A PROFILES
PROFILES["powersave"]="1300 210"
PROFILES["balanced"]="2200 2010"
PROFILES["gmode-lite"]="2000 1905"
PROFILES["gmode-max"]="2800 2400"

show_help() {
    echo "Usage: gmode [OPTIONS]"
    echo ""
    echo "Profiles:"
    echo "  -p <name>      Apply a profile (powersave, balanced, gmode-lite, gmode-max)"
    echo ""
    echo "Custom values:"
    echo "  -c <mhz>       Set CPU max frequency (${CPU_MIN}-${CPU_MAX} MHz)"
    echo "  -g <mhz>       Set GPU locked frequency (${GPU_MIN}-${GPU_MAX} MHz)"
    echo ""
    echo "Options:"
    echo "  -r             Reset (unlock) all clocks"
    echo "  -s             Show current status"
    echo "  -h             Show this help message"
    echo ""
    echo "Available Profiles:"
    for p in "powersave" "balanced" "gmode-lite" "gmode-max"; do
        read -r c g <<< "${PROFILES[$p]}"
        printf "  %-12s: CPU %4dMHz, GPU %4dMHz\n" "$p" "$c" "$g"
    done
}

show_status() {
    echo "--- Current Status ---"
    echo "CPU Scaling Max: $(cat /sys/devices/system/cpu/cpu0/cpufreq/scaling_max_freq 2>/dev/null || echo "N/A") KHz"
    echo "GPU Locked Clocks: $(sudo nvidia-smi --query-gpu=clocks.applications.graphics --format=csv,noheader 2>/dev/null || echo "N/A")"
    sudo nvidia-smi -d CLOCK
}

apply_settings() {
    local cpu=$1
    local gpu=$2

    if [ -n "$cpu" ]; then
        if (( cpu < CPU_MIN || cpu > CPU_MAX )); then
            echo "Error: CPU frequency $cpu MHz is out of range ($CPU_MIN-$CPU_MAX)"
            exit 1
        fi
        echo "Setting CPU max frequency to ${cpu}MHz..."
        sudo cpupower frequency-set -u "${cpu}MHz" > /dev/null
    fi

    if [ -n "$gpu" ]; then
        if (( gpu < GPU_MIN || gpu > GPU_MAX )); then
            echo "Error: GPU frequency $gpu MHz is out of range ($GPU_MIN-$GPU_MAX)"
            exit 1
        fi
        echo "Locking GPU clocks to ${gpu}MHz..."
        # nvidia-smi expects min,max. Locking to single value.
        sudo nvidia-smi --lock-gpu-clocks="$gpu,$gpu" > /dev/null
    fi
    
    echo "Done."
}

reset_settings() {
    echo "Resetting to default (unlocked) settings..."
    sudo cpupower frequency-set -u "${CPU_MAX}MHz" > /dev/null
    sudo nvidia-smi --reset-gpu-clocks > /dev/null
    echo "Reset complete."
}

# Parse arguments
if [ $# -eq 0 ]; then
    show_help
    exit 1
fi

PROFILE=""
CUSTOM_CPU=""
CUSTOM_GPU=""

while getopts "p:c:g:rsh" opt; do
    case ${opt} in
        p )
            PROFILE=$OPTARG
            ;;
        c )
            CUSTOM_CPU=$OPTARG
            ;;
        g )
            CUSTOM_GPU=$OPTARG
            ;;
        r )
            reset_settings
            exit 0
            ;;
        s )
            show_status
            exit 0
            ;;
        h )
            show_help
            exit 0
            ;;
        \? )
            show_help
            exit 1
            ;;
    esac
done

if [ -n "$PROFILE" ]; then
    if [[ -v PROFILES[$PROFILE] ]]; then
        read -r c g <<< "${PROFILES[$PROFILE]}"
        apply_settings "$c" "$g"
    else
        echo "Error: Unknown profile '$PROFILE'"
        echo "Available profiles: ${!PROFILES[*]}"
        exit 1
    fi
elif [ -n "$CUSTOM_CPU" ] || [ -n "$CUSTOM_GPU" ]; then
    apply_settings "$CUSTOM_CPU" "$CUSTOM_GPU"
else
    show_help
    exit 1
fi
